{
  "name": "schummar-job",
  "version": "0.8.1",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": {
    "name": "Marco Schumacher",
    "email": "marco@schumacher.dev"
  },
  "repository": "schummar/schummar-job",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "build:clean": "rimraf dist/**",
    "build:compile:esm": "tsc",
    "build:compile:cjs": "tsc -p tsconfig-cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "lint": "runp lint:*",
    "lint:oxlint": "oxlint --type-check",
    "lint:oxfmt": "oxfmt --check",
    "publint": "publint",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "node-object-hash": "^3.1.1"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@nx/js": "^22.6.5",
    "@schummar/runp": "2.2.4",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "cron-schedule": "6.0.0",
    "fast-equals": "6.0.0",
    "mongodb": "7.2.0",
    "nanoid": "5.1.9",
    "nx": "^22.6.5",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "publint": "^0.3.18",
    "schummar-queue": "0.4.0",
    "tsdown": "^0.21.9",
    "typescript": "6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "mongodb": ">=6.0.0"
  },
  "volta": {
    "node": "24.11.1",
    "npm": "11.7.0",
    "pnpm": "10.25.0"
  },
  "inlinedDependencies": {
    "cron-schedule": "6.0.0",
    "nanoid": "5.1.9",
    "schummar-queue": "0.4.0"
  }
}
